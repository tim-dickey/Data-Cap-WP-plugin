# Environment Configuration for Visitor Contact Collector Plugin
# Copy this file to .env and customize for your environment

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Application Environment (development, staging, production)
VCC_ENVIRONMENT=development

# Plugin Settings
VCC_DEBUG=false
VCC_LOG_LEVEL=info

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# WordPress Test Database (for automated testing)
WP_TEST_DB_NAME=wordpress_test
WP_TEST_DB_USER=root
WP_TEST_DB_PASS=root
WP_TEST_DB_HOST=localhost
WP_TEST_DB_PORT=3306

# WordPress Version for Testing
WP_TEST_VERSION=latest

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Default notification email (fallback if WordPress admin_email not set)
VCC_DEFAULT_ADMIN_EMAIL=admin@yoursite.com

# Email notifications enabled by default
VCC_EMAIL_NOTIFICATIONS=true

# SMTP Configuration (optional - for enhanced email delivery)
VCC_SMTP_HOST=
VCC_SMTP_PORT=587
VCC_SMTP_USERNAME=
VCC_SMTP_PASSWORD=
VCC_SMTP_ENCRYPTION=tls

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Rate limiting settings
VCC_RATE_LIMIT_ENABLED=true
VCC_RATE_LIMIT_ATTEMPTS=5
VCC_RATE_LIMIT_WINDOW=900

# Honeypot field name (for spam protection)
VCC_HONEYPOT_FIELD=website_url

# Data encryption key (leave empty to use WordPress AUTH_KEY)
VCC_ENCRYPTION_KEY=

# =============================================================================
# GDPR COMPLIANCE
# =============================================================================

# Data retention period (days)
VCC_DATA_RETENTION_DAYS=730

# Automatic data cleanup enabled
VCC_AUTO_CLEANUP=true

# Privacy policy URL (optional)
VCC_PRIVACY_POLICY_URL=

# Cookie consent integration
VCC_COOKIE_CONSENT=false

# =============================================================================
# API CONFIGURATION
# =============================================================================

# External service integrations (optional)
VCC_MAILCHIMP_API_KEY=
VCC_MAILCHIMP_LIST_ID=

VCC_SENDGRID_API_KEY=

VCC_RECAPTCHA_SITE_KEY=
VCC_RECAPTCHA_SECRET_KEY=

# Webhook endpoints for form submissions
VCC_WEBHOOK_URL=
VCC_WEBHOOK_SECRET=

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# WordPress.org SVN credentials (for plugin deployment)
SVN_USERNAME=
SVN_PASSWORD=

# GitHub repository information
GITHUB_OWNER=your-username
GITHUB_REPO=Data-Cap-WP-plugin

# Codacy configuration
CODACY_PROJECT_TOKEN=
CODACY_API_TOKEN=

# =============================================================================
# ASSET CONFIGURATION
# =============================================================================

# CDN settings for assets
VCC_USE_CDN=false
VCC_CDN_URL=

# Asset optimization
VCC_MINIFY_CSS=true
VCC_MINIFY_JS=true
VCC_COMPRESS_IMAGES=true

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================

# Test environment settings
VCC_TEST_MODE=false
VCC_TEST_EMAIL=test@example.com

# Code coverage thresholds
VCC_COVERAGE_THRESHOLD=80

# Performance testing
VCC_PERFORMANCE_TESTS=false
VCC_LOAD_TEST_USERS=100

# =============================================================================
# MONITORING & LOGGING
# =============================================================================

# Error reporting
VCC_ERROR_REPORTING=true
VCC_LOG_ERRORS=true
VCC_LOG_FILE_PATH=

# Analytics integration
VCC_GOOGLE_ANALYTICS_ID=
VCC_TRACKING_ENABLED=false

# Health check endpoint
VCC_HEALTH_CHECK_ENABLED=true

# =============================================================================
# CUSTOM CONFIGURATION
# =============================================================================

# Custom CSS/JS file paths
VCC_CUSTOM_CSS_PATH=
VCC_CUSTOM_JS_PATH=

# Form customization
VCC_FORM_THEME=default
VCC_CUSTOM_FIELDS=

# Notification templates
VCC_EMAIL_TEMPLATE_PATH=