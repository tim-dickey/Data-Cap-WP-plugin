# Local Environment Configuration
# This file is automatically created from .env.example
# Customize these values for your local development environment

VCC_ENVIRONMENT=development
VCC_DEBUG=true
VCC_LOG_LEVEL=debug

WP_TEST_DB_NAME=wordpress_test
WP_TEST_DB_USER=root
WP_TEST_DB_PASS=root
WP_TEST_DB_HOST=localhost
WP_TEST_DB_PORT=3306
WP_TEST_VERSION=latest

VCC_DEFAULT_ADMIN_EMAIL=admin@localhost.local
VCC_EMAIL_NOTIFICATIONS=true

VCC_RATE_LIMIT_ENABLED=false
VCC_RATE_LIMIT_ATTEMPTS=10
VCC_RATE_LIMIT_WINDOW=300

VCC_HONEYPOT_FIELD=website_url
VCC_DATA_RETENTION_DAYS=30
VCC_AUTO_CLEANUP=false

VCC_TEST_MODE=true
VCC_TEST_EMAIL=test@localhost.local
VCC_COVERAGE_THRESHOLD=80
VCC_PERFORMANCE_TESTS=true
VCC_LOAD_TEST_USERS=50

VCC_ERROR_REPORTING=true
VCC_LOG_ERRORS=true
VCC_HEALTH_CHECK_ENABLED=true

VCC_MINIFY_CSS=false
VCC_MINIFY_JS=false
VCC_COMPRESS_IMAGES=false

GITHUB_OWNER=your-username
GITHUB_REPO=Data-Cap-WP-plugin